# Sanity CMS configuration (used by the blog at /blog)
# 1. Crea tu proyecto en https://sanity.io/manage
# 2. Copia estos valores a un nuevo archivo .env.local
# 3. Cuando tengas posts, cambia BLOG_ENABLED a true en app/[locale]/blog/page.tsx

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
